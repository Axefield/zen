# Production Environment Variables
# Copy to .env.prod and fill in real values.
# NEVER commit .env.prod to version control.

# --- Database ---
DB_PASSWORD=change_me_to_a_random_64_char_string

# --- Meilisearch ---
MEILI_MASTER_KEY=change_me_to_a_random_40_char_string

# --- Strapi Secrets (generate unique random values for each) ---
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=change_me_random_string
STRAPI_ADMIN_JWT_SECRET=change_me_random_string
STRAPI_ADMIN_ENCRYPTION_KEY=change_me_random_string
STRAPI_TRANSFER_TOKEN_SALT=change_me_random_string
STRAPI_JWT_SECRET=change_me_random_string

# --- AI Engine ---
JWT_SECRET=change_me_random_string
STRAPI_API_TOKEN=create_this_via_strapi_admin_or_cli
OPENAI_API_KEY=

# --- Ollama (optional) ---
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
AI_PROVIDER=ollama
