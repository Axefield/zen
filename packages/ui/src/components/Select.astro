---
export interface Option {
  value: string
  label: string
}

export interface Props {
  name: string
  label?: string
  options: Option[]
  value?: string
  error?: string
  required?: boolean
  placeholder?: string
  class?: string
}

const { name, label, options, value, error, required, placeholder, class: className = "" } = Astro.props
---

<div class={`field ${className}`}>
  {label && <label for={name}>{label}{required && <span class="required">*</span>}</label>}
  <select {name} id={name} {required} class={error ? "input-error" : ""}>
    {placeholder && <option value="">{placeholder}</option>}
    {options.map((opt) => (
      <option value={opt.value} selected={opt.value === value}>{opt.label}</option>
    ))}
  </select>
  {error && <p class="error-text">{error}</p>}
</div>

<style>
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  label {
    font-size: var(--text-small);
    font-weight: var(--font-weight-medium);
    color: var(--text-primary);
  }

  .required {
    color: var(--color-error);
    margin-left: var(--spacing-1);
  }

  select {
    padding: var(--spacing-2) var(--spacing-3);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    font-size: var(--text-body);
    font-family: inherit;
    background: var(--bg-card);
    color: var(--text-primary);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    cursor: pointer;
  }

  select:focus {
    outline: none;
    border-color: var(--color-primary-400);
    box-shadow: 0 0 0 3px var(--color-primary-100);
  }

  select.input-error {
    border-color: var(--color-error);
  }

  select.input-error:focus {
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.15);
  }

  .error-text {
    margin: 0;
    font-size: var(--text-caption);
    color: var(--color-error);
  }
</style>
