---
export interface Props {
  variant?: "primary" | "secondary" | "ghost" | "danger"
  size?: "sm" | "md" | "lg"
  href?: string
  disabled?: boolean
  type?: "button" | "submit" | "reset"
  class?: string
}

const { variant = "primary", size = "md", href, disabled, type = "button", class: className = "" } = Astro.props
const tag = href ? "a" : "button"
---

{
  tag === "a" ? (
    <a href={href} class={`btn btn-${variant} btn-${size} ${className}`}>
      <slot />
    </a>
  ) : (
    <button type={type} disabled={disabled} class={`btn btn-${variant} btn-${size} ${className}`}>
      <slot />
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
    font-family: inherit;
    font-weight: var(--font-weight-medium);
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    cursor: pointer;
    text-decoration: none;
    line-height: var(--line-height-normal);
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast);
    white-space: nowrap;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-sm {
    padding: var(--spacing-1) var(--spacing-3);
    font-size: var(--text-small);
  }

  .btn-md {
    padding: var(--spacing-2) var(--spacing-4);
    font-size: var(--text-body);
  }

  .btn-lg {
    padding: var(--spacing-3) var(--spacing-6);
    font-size: var(--text-body);
  }

  .btn-primary {
    background: var(--color-primary-500);
    color: var(--text-inverse);
    border-color: var(--color-primary-500);
  }

  .btn-primary:hover:not(:disabled) {
    background: var(--color-primary-600);
    border-color: var(--color-primary-600);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-primary-500);
    border-color: var(--color-primary-300);
  }

  .btn-secondary:hover:not(:disabled) {
    background: var(--color-primary-50);
    border-color: var(--color-primary-400);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text-secondary);
    border-color: transparent;
  }

  .btn-ghost:hover:not(:disabled) {
    background: var(--color-neutral-100);
    color: var(--text-primary);
  }

  .btn-danger {
    background: var(--color-error);
    color: var(--text-inverse);
    border-color: var(--color-error);
  }

  .btn-danger:hover:not(:disabled) {
    background: #b91c1c;
    border-color: #b91c1c;
  }
</style>
