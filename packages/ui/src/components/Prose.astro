---
export interface Props {
  class?: string
  html?: string
}

const { class: className = "", html } = Astro.props
---

{
  html
    ? <div class={`prose ${className}`} set:html={html} />
    : <div class={`prose ${className}`}><slot /></div>
}

<style>
  .prose {
    max-width: 720px;
    font-size: var(--text-body);
    line-height: var(--line-height-relaxed);
    color: var(--text-primary);
  }

  .prose :global(p) { margin: 0 0 var(--spacing-4); }
  .prose :global(h2) {
    margin: var(--spacing-8) 0 var(--spacing-3);
    font-size: var(--text-heading-2);
    letter-spacing: -0.02em;
    line-height: var(--line-height-tight);
  }
  .prose :global(h3) {
    margin: var(--spacing-6) 0 var(--spacing-2);
    font-size: var(--text-heading-3);
    letter-spacing: -0.02em;
    line-height: var(--line-height-tight);
  }
  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 var(--spacing-4);
    padding-left: var(--spacing-6);
  }
  .prose :global(li) { margin-bottom: var(--spacing-2); }
  .prose :global(blockquote) {
    margin: var(--spacing-6) 0;
    padding: var(--spacing-4) var(--spacing-6);
    border-left: 3px solid var(--color-primary-500);
    background: var(--color-primary-50);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .prose :global(blockquote p) { margin: 0; }
  .prose :global(hr) {
    margin: var(--spacing-8) 0;
    border: none;
    border-top: 1px solid var(--border-light);
  }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: var(--radius-md); }
  .prose :global(a) { color: var(--color-primary-500); text-decoration: underline; }
  .prose :global(a:hover) { color: var(--color-primary-600); }
  .prose :global(code) {
    font-family: var(--font-family-mono);
    font-size: 0.9em;
    padding: 2px 6px;
    background: var(--color-neutral-100);
    border-radius: var(--radius-sm);
  }
  .prose :global(pre) {
    margin: var(--spacing-4) 0;
    padding: var(--spacing-4);
    background: var(--color-neutral-900);
    color: var(--text-inverse);
    border-radius: var(--radius-md);
    overflow-x: auto;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }
</style>
