---
export interface Props {
  size?: "sm" | "md" | "lg" | "full"
  padding?: "none" | "sm" | "md" | "lg"
  class?: string
}

const { size = "lg", padding = "md", class: className = "" } = Astro.props
---

<div class={`container container-${size} pad-${padding} ${className}`}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    margin: 0 auto;
  }

  .container-sm { max-width: 720px; }
  .container-md { max-width: 960px; }
  .container-lg { max-width: var(--content-max-width); }
  .container-full { max-width: 100%; }

  .pad-none { padding: 0; }
  .pad-sm { padding: 0 var(--spacing-4); }
  .pad-md { padding: 0 var(--spacing-6); }
  .pad-lg { padding: 0 var(--spacing-8); }
</style>
