---
import Hero from "./Hero.astro"
import RichTextBlock from "./RichTextBlock.astro"
import CallToAction from "./CallToAction.astro"
import MediaGallery from "./MediaGallery.astro"
import PricingTable from "./PricingTable.astro"
import TestimonialCard from "./TestimonialCard.astro"
import type { DynamicBlock } from "./types"

export type { DynamicBlock }

export interface Props {
  blocks: DynamicBlock[]
  resolveMediaUrl?: (url: string) => string
  class?: string
}

const { blocks = [], resolveMediaUrl, class: className = "" } = Astro.props

function resolveUrl(url: string): string {
  return resolveMediaUrl ? resolveMediaUrl(url) : url
}

function resolveMedia(m: Record<string, unknown> | undefined | null): Record<string, unknown> | undefined {
  if (!m) return undefined
  return { ...m, url: resolveUrl((m as { url?: string }).url ?? "") }
}

function resolveMediaArray(arr: unknown[] | undefined | null): Record<string, unknown>[] | undefined {
  if (!arr) return undefined
  return arr.map((m) => resolveMedia(m as Record<string, unknown>))
}
---

<div class={`dynamic-zone ${className}`}>
  {blocks.map((block) => {
    const b = block as any
    switch (block.__component) {
      case "shared.hero":
        return <Hero
          headline={b.headline}
          subheadline={b.subheadline}
          backgroundMedia={resolveMedia(b.backgroundMedia)}
          primaryCta={b.primaryCta ? { ...b.primaryCta, buttonText: b.primaryCta.buttonText ?? "", buttonUrl: b.primaryCta.buttonUrl ?? "" } : undefined}
        />
      case "shared.rich-text-block":
        return <RichTextBlock
          body={b.body}
          media={resolveMediaArray(b.media)}
        />
      case "shared.call-to-action":
        return <CallToAction
          headline={b.headline}
          body={b.body}
          buttonText={b.buttonText}
          buttonUrl={b.buttonUrl}
          variant={b.variant ?? "primary"}
        />
      case "shared.media-gallery":
        return <MediaGallery
          media={resolveMediaArray(b.media)}
          layout={b.layout ?? "grid"}
        />
      case "shared.pricing-table":
        return <PricingTable
          headline={b.headline}
          tiers={b.tiers}
        />
      case "shared.testimonial-card":
        return <TestimonialCard
          quote={b.quote}
          author={b.author}
          role={b.role}
          company={b.company}
          avatar={resolveMedia(b.avatar)}
        />
      default:
        return <p class="unknown-block">Unknown block: {block.__component}</p>
    }
  })}
</div>
