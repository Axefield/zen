---
import Prose from "../Prose.astro"

export interface Props {
  body: string
  media?: Array<{
    url: string
    alternativeText?: string
    formats?: Record<string, { url: string }>
  }>
  class?: string
}

const { body, media, class: className = "" } = Astro.props
---

<section class={`richtext-block ${className}`}>
  <Prose html={body} />
  {media && media.length > 0 && (
    <div class="richtext-media">
      {media.map((m) => (
        <figure>
          <img src={m.url} alt={m.alternativeText ?? ""} loading="lazy" />
        </figure>
      ))}
    </div>
  )}
</section>

<style>
  .richtext-block {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--spacing-12) var(--spacing-6);
  }

  .richtext-media {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-4);
    margin-top: var(--spacing-8);
  }

  .richtext-media figure {
    margin: 0;
  }

  .richtext-media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
  }
</style>
