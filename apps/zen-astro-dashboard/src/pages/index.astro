---
import DashboardLayout from "../layouts/DashboardLayout.astro"
import { fetchDashboardMetrics } from "../lib/api"
import Card from "@truligon/ui/Card"
import Badge from "@truligon/ui/Badge"

const metrics = await fetchDashboardMetrics()
---

<DashboardLayout title="Overview">
  <h1>Dashboard</h1>
  <p class="subtitle">System health, content inventory, and operational signals.</p>

  <div class="metrics-grid">
    <Card>
      <span class="label">API Status</span>
      <strong class={metrics.apiStatus === "ok" ? "ok" : "error"}>{metrics.apiStatus}</strong>
    </Card>

    <Card>
      <span class="label">Total Content Items</span>
      <strong>{metrics.totalContent}</strong>
    </Card>

    <Card>
      <span class="label">Active Modules</span>
      <strong>{metrics.apiModules.length || "—"}</strong>
    </Card>

    <Card>
      <span class="label">API Modules</span>
      <div class="tags">
        {metrics.apiModules.length > 0
          ? metrics.apiModules.map((m) => <Badge variant="default">{m}</Badge>)
          : "—"
        }
      </div>
    </Card>
  </div>

  <section class="content-breakdown">
    <h2>Content by Type</h2>
    <div class="breakdown-grid">
      {["Pages", "Articles", "Products", "Courses", "Events"].map((type) => {
        const key = type.toLowerCase() as keyof typeof metrics.contentBreakdown
        return (
          <Card padding="sm" class="stat">
            <span>{type}</span>
            <strong>{metrics.contentBreakdown[key]}</strong>
          </Card>
        )
      })}
    </div>
  </section>
</DashboardLayout>

<style>
  h1 {
    font-size: var(--text-heading-1);
    margin: 0 0 var(--spacing-2);
  }

  .subtitle {
    color: var(--text-secondary);
    margin: 0 0 var(--spacing-8);
    font-size: var(--text-body);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-8);
  }

  .label {
    display: block;
    color: var(--text-secondary);
    font-size: var(--text-small);
    margin-bottom: var(--spacing-2);
  }

  :global(.metrics-grid) strong {
    display: block;
    font-size: var(--text-heading-2);
  }

  .ok { color: var(--color-success); }
  .error { color: var(--color-error); }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
    font-size: var(--text-small);
  }

  .content-breakdown h2 {
    font-size: var(--text-heading-3);
    margin: 0 0 var(--spacing-4);
  }

  .breakdown-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--spacing-3);
  }

  .stat {
    text-align: center;
  }

  .stat span {
    display: block;
    font-size: var(--text-small);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-2);
  }

  .stat strong {
    font-size: var(--text-heading-2);
  }
</style>
