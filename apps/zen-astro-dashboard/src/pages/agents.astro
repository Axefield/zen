---
import DashboardLayout from "../layouts/DashboardLayout.astro"
import Card from "@truligon/ui/Card"
import Badge from "@truligon/ui/Badge"
import Button from "@truligon/ui/Button"
import ChatInterface from "../components/ChatInterface.tsx"
import "../components/ChatInterface.css"

const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:4000"
---

<DashboardLayout title="Agents">
  <div class="header">
    <div>
      <h1>AI Agents</h1>
      <p class="subtitle">Manage and interact with AI agents powered by Ollama.</p>
    </div>
    <Button variant="primary">New Agent</Button>
  </div>

  <section class="chat-section">
    <h2>Chat</h2>
    <p class="text-muted">Send a message to the AI engine to test the connection.</p>
    <ChatInterface apiUrl={API_URL} client:load />
  </section>

  <section>
    <h2>Available Agents</h2>
    <div class="agent-grid">
      <Card>
        <h3>Research Agent</h3>
        <Badge variant="default">research</Badge>
        <p>Conduct research and gather information on topics.</p>
      </Card>
      <Card>
        <h3>Content Agent</h3>
        <Badge variant="default">content</Badge>
        <p>Generate and optimize content.</p>
      </Card>
      <Card>
        <h3>UX Agent</h3>
        <Badge variant="default">ux</Badge>
        <p>Analyze user experience patterns.</p>
      </Card>
    </div>
  </section>
</DashboardLayout>

<style>
  h1 {
    font-size: var(--text-heading-1);
    margin: 0;
  }

  h2 {
    font-size: var(--text-heading-3);
    margin: 0 0 var(--spacing-3);
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--spacing-8);
  }

  .subtitle {
    color: var(--text-secondary);
    margin: var(--spacing-1) 0 0;
    font-size: var(--text-body);
  }

  .text-muted {
    color: var(--text-muted);
    font-size: var(--text-small);
    margin: 0 0 var(--spacing-4);
  }

  .chat-section {
    margin-bottom: var(--spacing-8);
  }

  .agent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--spacing-4);
  }

  .agent-grid h3 {
    margin: 0 0 var(--spacing-2);
    font-size: var(--text-body);
  }

  .agent-grid p {
    margin: var(--spacing-2) 0 0;
    font-size: var(--text-small);
    color: var(--text-secondary);
  }
</style>
