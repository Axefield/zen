---
import DashboardLayout from "../../layouts/DashboardLayout.astro"
import { fetchStrapiCollection } from "../../lib/api"
import Card from "@truligon/ui/Card"
import Badge from "@truligon/ui/Badge"
import Heading from "@truligon/ui/Heading"
import Text from "@truligon/ui/Text"
import Button from "@truligon/ui/Button"
import DeleteButton from "../../components/DeleteButton.tsx"
import "../../components/DeleteButton.css"

const API_URL = import.meta.env.INTERNAL_API_URL || process.env.INTERNAL_API_URL || "http://ai-engine:4000"

interface StrapiArticle {
  id: number
  title: string
  slug: string
  excerpt: string
  publishedAt: string
}

const articles = await fetchStrapiCollection<StrapiArticle>("articles", {
  sort: "publishedAt:desc",
  "pagination[limit]": "100",
})
---

<DashboardLayout title="Articles">
  <div class="header-row">
    <div>
      <a href="/content" class="back-link">← Content</a>
      <Heading level={1}>Articles</Heading>
      <Text color="secondary" class="subtitle">{articles.length} article{articles.length !== 1 ? "s" : ""} total.</Text>
    </div>
    <Button href="/content/articles/new" variant="primary">New Article</Button>
  </div>

  {articles.length > 0 ? (
    <div class="table-wrapper">
      <table class="content-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Slug</th>
            <th>Published</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {articles.map((article) => (
            <tr>
              <td>
                <strong>{article.title}</strong>
                <p class="excerpt">{article.excerpt}</p>
              </td>
              <td><code>/{article.slug}</code></td>
              <td>
                {article.publishedAt
                  ? new Date(article.publishedAt).toLocaleDateString()
                  : "—"
                }
              </td>
              <td class="actions-cell">
                <a href={`/content/articles/${article.id}`} class="action-link">Edit</a>
                <DeleteButton collection="articles" id={article.id} title={article.title} apiUrl={API_URL} client:load />
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <Card padding="lg">
      <Text color="muted">No articles found.</Text>
    </Card>
  )}
</DashboardLayout>

<style>
  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--spacing-6);
  }
  .back-link {
    display: inline-block;
    font-size: var(--text-small);
    color: var(--text-muted);
    margin-bottom: var(--spacing-2);
    text-decoration: none;
  }
  .back-link:hover { color: var(--color-primary-500); text-decoration: underline; }
  .subtitle { margin: var(--spacing-1) 0 0; }
  .table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
  }
  .content-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-small);
  }
  .content-table th {
    text-align: left;
    padding: var(--spacing-3) var(--spacing-4);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
    background: var(--color-neutral-50);
  }
  .content-table td {
    padding: var(--spacing-3) var(--spacing-4);
    border-bottom: 1px solid var(--border-light);
    vertical-align: top;
  }
  .content-table tr:last-child td { border-bottom: none; }
  .excerpt { margin: var(--spacing-1) 0 0; color: var(--text-muted); font-size: var(--text-caption); }
  code { font-family: var(--font-family-mono); font-size: 0.9em; color: var(--text-secondary); }
  .actions-cell {
    white-space: nowrap;
    display: flex;
    gap: var(--spacing-2);
    align-items: center;
  }
  .action-link {
    font-size: var(--text-small);
    color: var(--color-primary-500);
    text-decoration: none;
  }
  .action-link:hover { text-decoration: underline; }
</style>
