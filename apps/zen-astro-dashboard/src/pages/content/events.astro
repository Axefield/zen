---
import DashboardLayout from "../../layouts/DashboardLayout.astro"
import { fetchStrapiCollection } from "../../lib/api"
import Card from "@truligon/ui/Card"
import Badge from "@truligon/ui/Badge"
import Heading from "@truligon/ui/Heading"
import Text from "@truligon/ui/Text"
import Button from "@truligon/ui/Button"
import DeleteButton from "../../components/DeleteButton.tsx"
import "../../components/DeleteButton.css"

const API_URL = import.meta.env.INTERNAL_API_URL || process.env.INTERNAL_API_URL || "http://ai-engine:4000"

interface StrapiEvent {
  id: number
  title: string
  slug: string
  date: string
  locationType: string
  capacity: number
}

const events = await fetchStrapiCollection<StrapiEvent>("events", {
  sort: "date:desc",
  "pagination[limit]": "100",
})
---

<DashboardLayout title="Events">
  <div class="header-row">
    <div>
      <a href="/content" class="back-link">← Content</a>
      <Heading level={1}>Events</Heading>
      <Text color="secondary" class="subtitle">{events.length} event{events.length !== 1 ? "s" : ""} total.</Text>
    </div>
    <Button href="/content/events/new" variant="primary">New Event</Button>
  </div>

  {events.length > 0 ? (
    <div class="table-wrapper">
      <table class="content-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Date</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {events.map((event) => (
            <tr>
              <td>
                <strong>{event.title}</strong>
                <p class="slug"><code>/{event.slug}</code></p>
              </td>
              <td>{event.date ? new Date(event.date).toLocaleDateString() : "—"}</td>
              <td>
                <Badge variant={event.locationType === "virtual" ? "info" : event.locationType === "hybrid" ? "warning" : "default"}>
                  {event.locationType}
                </Badge>
              </td>
              <td>{event.capacity ?? "—"}</td>
              <td class="actions-cell">
                <a href={`/content/events/${event.id}`} class="action-link">Edit</a>
                <DeleteButton collection="events" id={event.id} title={event.title} apiUrl={API_URL} client:load />
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <Card padding="lg">
      <Text color="muted">No events found.</Text>
    </Card>
  )}
</DashboardLayout>

<style>
  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--spacing-6);
  }
  .back-link {
    display: inline-block;
    font-size: var(--text-small);
    color: var(--text-muted);
    margin-bottom: var(--spacing-2);
    text-decoration: none;
  }
  .back-link:hover { color: var(--color-primary-500); text-decoration: underline; }
  .subtitle { margin: var(--spacing-1) 0 0; }
  .table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
  }
  .content-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-small);
  }
  .content-table th {
    text-align: left;
    padding: var(--spacing-3) var(--spacing-4);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
    background: var(--color-neutral-50);
  }
  .content-table td {
    padding: var(--spacing-3) var(--spacing-4);
    border-bottom: 1px solid var(--border-light);
  }
  .content-table tr:last-child td { border-bottom: none; }
  .slug { margin: var(--spacing-1) 0 0; }
  code { font-family: var(--font-family-mono); font-size: 0.9em; color: var(--text-secondary); }
  .actions-cell {
    white-space: nowrap;
    display: flex;
    gap: var(--spacing-2);
    align-items: center;
  }
  .action-link { font-size: var(--text-small); color: var(--color-primary-500); text-decoration: none; }
  .action-link:hover { text-decoration: underline; }
</style>
