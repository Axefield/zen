---

const year = new Date().getFullYear()
---

<footer class="site-footer">
  <div class="container">
    <div class="brand">
      <strong>Truligon's Zen</strong>
      <span class="tagline">Business Operating System</span>
    </div>
    <p class="copyright">&copy; {year} Truligon's Zen. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary-800);
    color: var(--color-primary-200);
    padding: var(--spacing-8) var(--spacing-6);
    margin-top: auto;
  }

  .container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .brand strong {
    font-size: var(--text-body);
    color: var(--text-inverse);
  }

  .tagline {
    font-size: var(--text-caption);
    opacity: 0.7;
  }

  .copyright {
    font-size: var(--text-small);
    opacity: 0.6;
    margin: 0;
  }
</style>
