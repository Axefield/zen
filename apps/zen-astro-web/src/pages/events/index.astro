---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { fetchCollection } from "../../lib/strapi"

interface StrapiEvent {
  id: number
  title: string
  slug: string
  description: string
  date: string
  locationType: "physical" | "virtual" | "hybrid"
  address?: string
  virtualUrl?: string
  publishedAt: string
}

let events: StrapiEvent[] = []
try {
  events = await fetchCollection<StrapiEvent>("events", { "sort": "date:desc", "pagination[limit]": "50" })
} catch {}
---

<BaseLayout title="Events" description="Upcoming events and gatherings.">
  <section class="page-header">
    <h1>Events</h1>
  </section>

  <section class="list">
    {events.length > 0 ? (
      <div class="grid">
        {events.map((event) => (
          <a href={`/events/${event.slug}`} class="card">
            <h2>{event.title}</h2>
            <p class="meta">
              <time datetime={event.date}>
                {new Date(event.date).toLocaleDateString("en-US", {
                  year: "numeric", month: "long", day: "numeric"
                })}
              </time>
              <span class="badge">{event.locationType}</span>
            </p>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">No upcoming events scheduled.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--spacing-12) var(--spacing-6) var(--spacing-8);
  }

  .page-header h1 {
    font-size: var(--text-heading-1);
    margin: 0;
  }

  .list {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-6) var(--spacing-12);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--spacing-4);
  }

  .card {
    display: block;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    padding: var(--spacing-6);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .card:hover {
    border-color: var(--color-primary-300);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .card h2 {
    margin: 0 0 var(--spacing-2);
    font-size: var(--text-heading-3);
  }

  .meta {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    font-size: var(--text-small);
    color: var(--text-secondary);
  }

  .badge {
    display: inline-block;
    padding: 2px var(--spacing-2);
    border-radius: var(--radius-sm);
    background: var(--color-primary-100);
    color: var(--color-primary-700);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-medium);
    text-transform: capitalize;
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }
</style>
