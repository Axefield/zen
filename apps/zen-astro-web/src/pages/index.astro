---
import BaseLayout from "../layouts/BaseLayout.astro"
import { fetchCollection } from "../lib/strapi"

interface StrapiArticle {
  id: number
  title: string
  slug: string
  excerpt: string
  publishedAt: string
}

interface StrapiPage {
  id: number
  title: string
  slug: string
}

let articles: StrapiArticle[] = []
let pages: StrapiPage[] = []

try {
  articles = await fetchCollection<StrapiArticle>("articles", { "sort": "publishedAt:desc", "pagination[limit]": "6" })
} catch {
  articles = []
}

try {
  pages = await fetchCollection<StrapiPage>("pages")
} catch {
  pages = []
}
---

<BaseLayout title="Home" description="Truligon's Zen Business Operating System — modular, type-safe, AI-augmented.">
  <section class="hero">
    <p class="eyebrow">Truligon's Zen Business Operating System</p>
    <h1>Modular operating layer for products, content, analytics, and AI-assisted workflows.</h1>
    <p class="lead">
      A type-safe, domain-agnostic platform for building digital products with reusable modules.
    </p>
  </section>

  {pages.length > 0 && (
    <section class="section">
      <h2>Pages</h2>
      <div class="grid">
        {pages.map((page) => (
          <a href={`/${page.slug}`} class="card">
            <h3>{page.title}</h3>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <h2>Latest Articles</h2>
    {articles.length > 0 ? (
      <div class="grid">
        {articles.map((article) => (
          <a href={`/articles/${article.slug}`} class="card">
            <h3>{article.title}</h3>
            <p>{article.excerpt}</p>
            <time datetime={article.publishedAt}>
              {new Date(article.publishedAt).toLocaleDateString()}
            </time>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">No articles yet. Add content in the Strapi admin panel.</p>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 980px;
    margin: 0 auto;
    padding: var(--spacing-16) var(--spacing-6) var(--spacing-12);
  }

  .eyebrow {
    margin: 0 0 var(--spacing-3);
    color: var(--color-primary-500);
    font-size: var(--text-small);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: var(--text-display);
    line-height: var(--line-height-tight);
  }

  .lead {
    max-width: 720px;
    margin: var(--spacing-6) 0 0;
    color: var(--text-secondary);
    font-size: var(--text-heading-3);
    line-height: var(--line-height-relaxed);
  }

  .section {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--spacing-12) var(--spacing-6);
  }

  .section h2 {
    font-size: var(--text-heading-2);
    margin: 0 0 var(--spacing-6);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-4);
  }

  .card {
    display: block;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    padding: var(--spacing-6);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .card:hover {
    border-color: var(--color-primary-300);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .card h3 {
    margin: 0 0 var(--spacing-2);
    font-size: var(--text-heading-3);
  }

  .card p {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--text-small);
    line-height: var(--line-height-normal);
  }

  .card time {
    display: block;
    margin-top: var(--spacing-3);
    color: var(--text-muted);
    font-size: var(--text-caption);
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }
</style>
