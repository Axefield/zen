---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { fetchCollection } from "../../lib/strapi"

interface StrapiCourse {
  id: number
  title: string
  slug: string
  description: string
  price?: number
  currency: string
  publishedAt: string
}

let courses: StrapiCourse[] = []
try {
  courses = await fetchCollection<StrapiCourse>("courses", { "sort": "title:asc", "pagination[limit]": "50" })
} catch {}
---

<BaseLayout title="Courses" description="Educational courses and training.">
  <section class="page-header">
    <h1>Courses</h1>
  </section>

  <section class="list">
    {courses.length > 0 ? (
      <div class="grid">
        {courses.map((course) => (
          <a href={`/courses/${course.slug}`} class="card">
            <h2>{course.title}</h2>
            {course.price != null && course.price > 0 && (
              <p class="price">
                {new Intl.NumberFormat("en-US", { style: "currency", currency: course.currency }).format(course.price)}
              </p>
            )}
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">No courses published yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--spacing-12) var(--spacing-6) var(--spacing-8);
  }

  .page-header h1 {
    font-size: var(--text-heading-1);
    margin: 0;
  }

  .list {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-6) var(--spacing-12);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--spacing-4);
  }

  .card {
    display: block;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    padding: var(--spacing-6);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .card:hover {
    border-color: var(--color-primary-300);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .card h2 {
    margin: 0 0 var(--spacing-2);
    font-size: var(--text-heading-3);
  }

  .price {
    margin: 0;
    font-size: var(--text-heading-3);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-500);
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }
</style>
