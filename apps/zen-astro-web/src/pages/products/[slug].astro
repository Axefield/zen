---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { fetchCollection } from "../../lib/strapi"

const { slug } = Astro.params

interface StrapiProduct {
  id: number
  name: string
  slug: string
  description: string
  price: number
  compareAtPrice?: number
  currency: string
  createdAt: string
  publishedAt: string
}

let product: StrapiProduct | null = null
try {
  const products = await fetchCollection<StrapiProduct>("products", { "filters[slug][$eq]": slug })
  product = products.length > 0 ? products[0] : null
} catch {}

if (!product) {
  return Astro.redirect("/products", 307)
}
---

<BaseLayout title={product.name} description={product.description}>
  <article class="product">
    <header>
      <p class="breadcrumb"><a href="/products">Products</a> /</p>
      <h1>{product.name}</h1>
      <p class="price">
        {new Intl.NumberFormat("en-US", { style: "currency", currency: product.currency }).format(product.price)}
        {product.compareAtPrice && (
          <span class="compare-at">
            {new Intl.NumberFormat("en-US", { style: "currency", currency: product.currency }).format(product.compareAtPrice)}
          </span>
        )}
      </p>
    </header>
    <div class="body">
      {product.description}
    </div>
  </article>
</BaseLayout>

<style>
  .product {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--spacing-12) var(--spacing-6);
  }

  header {
    margin-bottom: var(--spacing-8);
  }

  .breadcrumb {
    font-size: var(--text-small);
    color: var(--text-muted);
    margin: 0 0 var(--spacing-3);
  }

  .breadcrumb a {
    color: var(--color-primary-500);
  }

  h1 {
    font-size: var(--text-heading-1);
    margin: 0 0 var(--spacing-4);
  }

  .price {
    font-size: var(--text-heading-2);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-500);
    margin: 0;
  }

  .compare-at {
    margin-left: var(--spacing-2);
    font-size: var(--text-body);
    font-weight: var(--font-weight-normal);
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .body {
    font-size: var(--text-body);
    line-height: var(--line-height-relaxed);
    color: var(--text-primary);
  }

  .body :global(p) {
    margin: 0 0 var(--spacing-4);
  }

  .body :global(h2) {
    margin: var(--spacing-8) 0 var(--spacing-3);
    font-size: var(--text-heading-2);
  }

  .body :global(h3) {
    margin: var(--spacing-6) 0 var(--spacing-2);
    font-size: var(--text-heading-3);
  }
</style>
