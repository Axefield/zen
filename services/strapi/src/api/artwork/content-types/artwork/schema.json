{
  "kind": "collectionType",
  "collectionName": "artworks",
  "info": {
    "singularName": "artwork",
    "pluralName": "artworks",
    "displayName": "Artwork",
    "description": "Portfolio and gallery with licensing metadata"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": ["images", "files"]
    },
    "license": {
      "type": "enumeration",
      "enum": ["all-rights-reserved", "creative-commons", "royalty-free", "rights-managed", "editorial"]
    },
    "price": {
      "type": "decimal",
      "min": 0
    },
    "currency": {
      "type": "string",
      "default": "USD",
      "maxLength": 3
    },
    "artist": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.seo"
    }
  }
}
