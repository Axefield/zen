{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Flexible page builder with dynamic zones"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "dynamiczone",
      "components": ["shared.hero", "shared.rich-text-block", "shared.media-gallery", "shared.call-to-action", "shared.pricing-table", "shared.testimonial-card"],
      "required": false
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.seo"
    },
    "visibility": {
      "type": "enumeration",
      "enum": ["public", "private", "unlisted"],
      "default": "public"
    }
  }
}
